# ────────────────────────────────────────────
# 환경 변수 (절대 커밋하지 마세요)
# ────────────────────────────────────────────
.env
.env.local
.env.*.local

# ────────────────────────────────────────────
# Node.js
# ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ────────────────────────────────────────────
# Build outputs
# ────────────────────────────────────────────
frontend/dist/
backend/dist/

# ────────────────────────────────────────────
# Vite
# ────────────────────────────────────────────
frontend/.vite/

# ────────────────────────────────────────────
# TypeScript
# ────────────────────────────────────────────
*.tsbuildinfo

# ────────────────────────────────────────────
# OS
# ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────────
# Editor
# ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ────────────────────────────────────────────
# Kubernetes secrets (민감 정보 포함 파일)
# 실제 secret 값이 들어간 파일은 커밋하지 마세요
# ────────────────────────────────────────────
k8s/**/secret.yaml
!k8s/**/*.example.yaml

# ────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────
.dockerignore

# ────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────
logs/
*.log

# ────────────────────────────────────────────
