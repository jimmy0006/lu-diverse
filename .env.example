# ────────────────────────────────────────────
# Backend
# ────────────────────────────────────────────

# PostgreSQL 연결 정보 (특수문자 포함 비밀번호를 위해 개별 항목으로 입력)
DB_HOST=postgres
DB_PORT=5432
DB_USER=ludiverse
DB_PASSWORD=ludiverse_password
DB_NAME=ludiverse

# JWT 시크릿 (충분히 긴 무작위 문자열로 교체하세요)
JWT_SECRET=change_me_to_a_long_random_secret

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=your_s3_bucket_name

# 허용할 프론트엔드 Origin (개발환경)
CLIENT_ORIGIN=http://localhost:5173

# 서버 포트
PORT=4000

# ────────────────────────────────────────────
# PostgreSQL (docker-compose용)
# ────────────────────────────────────────────
POSTGRES_USER=ludiverse
POSTGRES_PASSWORD=ludiverse_password
POSTGRES_DB=ludiverse
